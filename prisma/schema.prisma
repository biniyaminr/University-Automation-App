// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(cuid())
  userId          String?           @unique // Clerk User ID
  fullName        String
  email           String            @unique
  phone           String?
  address         String?
  dob             DateTime?
  citizenship     String?
  zipCode         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  educations      Education[]
  testScores      TestScore[]
  extracurriculars Extracurricular[]
  documents       Document[]
  applications    Application[]
}

model Education {
  id              String   @id @default(cuid())
  institutionName String
  major           String?
  city            String?
  country         String?
  startDate       DateTime?
  gradDate        DateTime?
  gpa             Float?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TestScore {
  id        String   @id @default(cuid())
  testType  String   // e.g., SAT, ACT, IELTS, Duolingo
  score     String
  dateTaken DateTime?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Extracurricular {
  id           String   @id @default(cuid())
  role         String
  organization String
  startDate    DateTime?
  endDate      DateTime?
  hoursPerWeek Float?
  description  String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Document {
  id            String       @id @default(cuid())
  name          String
  type          String       // e.g., TRANSCRIPT, PASSPORT, RESUME
  fileUrl       String
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Application {
  id                   String   @id @default(cuid())
  universityName       String
  major                String?
  programName          String?
  url                  String?
  deadline             String?
  matchScore           Int?
  status               String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, READY, SUBMITTED
  portalUrl            String?
  userId               String
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents            Document[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model Opportunity {
  id              String   @id @default(cuid())
  userId          String?  // Clerk User ID if personal
  university      String
  programName     String
  description     String?
  deadline        DateTime?
  isScholarship   Boolean  @default(false)
  isFreeApp       Boolean  @default(false)
  country         String?
  link            String
  createdAt       DateTime @default(now())
}

